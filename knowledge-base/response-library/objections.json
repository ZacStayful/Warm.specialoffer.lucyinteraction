    {
      "canonical_trigger": "I want to understand the costs more",
      "trigger_variants": [
        "What are the total costs?",
        "I need to understand what the fees actually are",
        "I'm not clear on how much I'd actually keep",
        "What are the total costs involved \u2014 management fee, cleaning, etc?"
      ],
      "frequency": 8,
      "confidence": 0.8,
      "last_seen": "2026-05-25",
      "profile_types": [
        "STL-SW",
        "EX-STL",
        "ABROAD"
      ],
      "emotional_profiles": [
        "analytical-evaluator"
      ],
      "most_common_meeting_phase": "income_presented",
      "zac_response": {
        "best": "Show a worked example, not a percentage. 'At your projected \u00a3X gross, here's what you actually keep: platform (3%) = \u00a3A, management (13%) = \u00a3B, cleaning (est. \u00a3Y/year) = \u00a3C. You keep \u00a3D.' Give them the number, not the formula.",
        "alternatives": [
          "Send a one-page 'What you actually earn' breakdown after the meeting"
        ],
        "avoid": "Saying 'it's just 13% plus VAT' \u2014 that doesn't answer the question. They want to know what's left, not what you charge."
      },
      "resolution_rate": 0.7,
      "what_resolved_it": "A specific worked example with their property's numbers",
      "linked_delay_type": "",
      "linked_gap_category": "income_proof",
      "entries": []
    },
    {
      "canonical_trigger": "What about quiet months / income in winter?",
      "trigger_variants": [
        "What happens in January and February?",
        "I'm worried about income dropping off in winter",
        "How consistent is the income really?",
        "Still have concerns about quiet months"
      ],
      "frequency": 6,
      "confidence": 0.7,
      "last_seen": "2026-05-25",
      "profile_types": [
        "STL-SW",
        "PURCH",
        "ABROAD"
      ],
      "emotional_profiles": [
        "certainty-seeker"
      ],
      "most_common_meeting_phase": "income_presented",
      "zac_response": {
        "best": "Present worst-case monthly income, not averages. 'Even in our quietest month, a property like yours earns \u00a3X. Here's the month-by-month breakdown.' Then let the data speak. Leads who see the presentation twice resolve this concern themselves \u2014 if they don't challenge it on first viewing, send a follow-up invite 48 hours later.",
        "alternatives": [
          "Share a real monthly earnings statement from a comparable property (anonymised)",
          "Show the floor: 'Your worst-case month is still \u00a3X \u2014 that's your mortgage covered.'"
        ],
        "avoid": "Average annual figures without monthly breakdown. 'Trust us' without evidence."
      },
      "resolution_rate": 0.8,
      "what_resolved_it": "Month-by-month income data. Second pres view confirmed this resolves the concern on re-exposure.",
      "linked_delay_type": "",
      "linked_gap_category": "income_proof",
      "entries": []
    },
    {
      "canonical_trigger": "What type of guests will the property attract?",
      "trigger_variants": [
        "I'm worried about the wrong type of guests",
        "How do you screen guests?",
        "I want NHS/healthcare workers specifically",
        "Getting the right type of guests"
      ],
      "frequency": 5,
      "confidence": 0.6,
      "last_seen": "2026-05-29",
      "profile_types": [
        "STL-SW",
        "ABROAD"
      ],
      "emotional_profiles": [
        "certainty-seeker"
      ],
      "most_common_meeting_phase": "qualification",
      "zac_response": {
        "best": "Explain the vetting process specifically: 'We require a minimum review history, ID verification, and we take a security deposit. We can also decline bookings \u2014 you're not stuck with anyone Airbnb sends.' For leads wanting specific guest types (NHS, corporate): 'Your property's location already attracts those guests naturally. Here's why: [specific local demand drivers].'",
        "alternatives": [
          "Lead with guest vetting BEFORE income figures for this type of concern",
          "Show real examples of guest types at comparable properties"
        ],
        "avoid": "Vague reassurance without specifics. 'We only have good guests' is not an answer."
      },
      "resolution_rate": 0.6,
      "what_resolved_it": "Specific vetting process explanation + local demand driver narrative",
      "linked_delay_type": "",
      "linked_gap_category": "damage_protection",
