    {
      "canonical_trigger": "What if something gets damaged?",
      "trigger_variants": [
        "What about damage and theft?",
        "What happens if a guest breaks something?",
        "My renovation investment is exposed",
        "Emotional attachment to the property"
      ],
      "frequency": 5,
      "confidence": 0.6,
      "last_seen": "2026-05-28",
      "profile_types": [
        "EX-STL",
